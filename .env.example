# Токен Telegram-бота (получи у @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Authorization Key из GigaChat Studio (Base64: ClientID:ClientSecret)
# Получи на: https://developers.sber.ru/studio
GIGACHAT_AUTH_KEY=your_gigachat_base64_auth_key_here

# Scope: GIGACHAT_API_PERS (физлицо) или GIGACHAT_API_CORP (юрлицо)
GIGACHAT_SCOPE=GIGACHAT_API_PERS
